<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="UTF-8"/>
<meta name="viewport" content="width=device-width,initial-scale=1"/>
<title>ZyphraOS — 32-bit Operating System</title>
<link href="https://fonts.googleapis.com/css2?family=Share+Tech+Mono&family=Rajdhani:wght@400;600;700&family=Space+Mono:wght@400;700&display=swap" rel="stylesheet"/>
<style>
  :root {
    --bg:       #040810;
    --bg2:      #080f1c;
    --cyan:     #00ffe7;
    --cyan2:    #00bfad;
    --green:    #39ff6a;
    --red:      #ff3c5a;
    --amber:    #ffd24a;
    --text:     #c8d8e8;
    --dim:      #5a7088;
    --border:   rgba(0,255,231,.18);
    --glow:     0 0 18px rgba(0,255,231,.35), 0 0 60px rgba(0,255,231,.1);
    --font-mono: 'Share Tech Mono', monospace;
    --font-ui:   'Rajdhani', sans-serif;
  }

  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  html { scroll-behavior: smooth; }

  body {
    background: var(--bg);
    color: var(--text);
    font-family: var(--font-ui);
    font-size: 16px;
    line-height: 1.65;
    overflow-x: hidden;
  }

  /* ── SCANLINES OVERLAY ── */
  body::before {
    content: '';
    position: fixed; inset: 0;
    background: repeating-linear-gradient(0deg,
      transparent,
      transparent 3px,
      rgba(0,0,0,.07) 3px,
      rgba(0,0,0,.07) 4px);
    pointer-events: none;
    z-index: 9999;
  }

  /* ── NOISE GRAIN ── */
  body::after {
    content: '';
    position: fixed; inset: 0;
    background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)' opacity='.035'/%3E%3C/svg%3E");
    pointer-events: none;
    z-index: 9998;
    opacity: .5;
  }

  /* ── SCROLLBAR ── */
  ::-webkit-scrollbar { width: 4px; }
  ::-webkit-scrollbar-track { background: var(--bg2); }
  ::-webkit-scrollbar-thumb { background: var(--cyan2); border-radius: 2px; }

  /* ── NAV ── */
  nav {
    position: fixed; top: 0; left: 0; right: 0; z-index: 1000;
    display: flex; align-items: center; justify-content: space-between;
    padding: .9rem 2.5rem;
    background: rgba(4,8,16,.85);
    backdrop-filter: blur(14px);
    border-bottom: 1px solid var(--border);
  }
  .nav-logo {
    font-family: var(--font-mono);
    font-size: 1.15rem;
    color: var(--cyan);
    text-shadow: var(--glow);
    letter-spacing: .08em;
  }
  .nav-logo span { color: var(--green); }
  .nav-links { display: flex; gap: 2rem; list-style: none; }
  .nav-links a {
    font-family: var(--font-mono);
    font-size: .78rem;
    color: var(--dim);
    text-decoration: none;
    letter-spacing: .12em;
    text-transform: uppercase;
    transition: color .2s;
  }
  .nav-links a:hover { color: var(--cyan); text-shadow: var(--glow); }

  /* ── HERO ── */
  #hero {
    min-height: 100vh;
    display: grid;
    place-items: center;
    padding: 7rem 2rem 4rem;
    position: relative;
    overflow: hidden;
  }

  /* Radial glow behind hero */
  #hero::before {
    content: '';
    position: absolute;
    top: 20%; left: 50%; transform: translate(-50%,-50%);
    width: 700px; height: 700px;
    background: radial-gradient(ellipse, rgba(0,255,231,.08) 0%, transparent 70%);
    pointer-events: none;
  }

  /* Grid dots bg */
  #hero::after {
    content: '';
    position: absolute; inset: 0;
    background-image:
      radial-gradient(circle, rgba(0,255,231,.12) 1px, transparent 1px);
    background-size: 36px 36px;
    pointer-events: none;
    animation: gridScroll 30s linear infinite;
  }
  @keyframes gridScroll { to { background-position: 36px 36px; } }

  .hero-inner {
    position: relative; z-index: 2;
    max-width: 860px;
    text-align: center;
  }

  .hero-badge {
    display: inline-block;
    font-family: var(--font-mono);
    font-size: .72rem;
    letter-spacing: .2em;
    color: var(--cyan);
    border: 1px solid var(--border);
    padding: .35rem 1rem;
    margin-bottom: 2rem;
    text-transform: uppercase;
    animation: fadeDown .6s ease both;
  }

  .hero-title {
    font-family: var(--font-mono);
    font-size: clamp(3rem, 10vw, 6.5rem);
    line-height: 1;
    color: #fff;
    text-shadow: 0 0 40px rgba(0,255,231,.4), 0 0 2px rgba(0,255,231,.8);
    animation: fadeDown .7s ease .1s both;
    letter-spacing: -.02em;
  }

  .hero-title .accent { color: var(--cyan); }

  .hero-sub {
    font-family: var(--font-mono);
    font-size: .95rem;
    color: var(--dim);
    margin: 1.4rem 0 2.5rem;
    animation: fadeDown .7s ease .2s both;
    letter-spacing: .05em;
  }

  .hero-tags {
    display: flex; flex-wrap: wrap; gap: .6rem;
    justify-content: center;
    margin-bottom: 2.8rem;
    animation: fadeDown .7s ease .3s both;
  }
  .tag {
    font-family: var(--font-mono);
    font-size: .7rem;
    padding: .28rem .8rem;
    border: 1px solid var(--border);
    color: var(--cyan2);
    letter-spacing: .12em;
    text-transform: uppercase;
  }
  .tag.green { border-color: rgba(57,255,106,.3); color: var(--green); }
  .tag.amber { border-color: rgba(255,210,74,.3); color: var(--amber); }

  .hero-btns {
    display: flex; gap: 1rem; justify-content: center; flex-wrap: wrap;
    animation: fadeDown .7s ease .4s both;
  }

  .btn-primary {
    display: inline-flex; align-items: center; gap: .5rem;
    background: var(--cyan);
    color: var(--bg);
    font-family: var(--font-mono);
    font-size: .82rem;
    font-weight: 700;
    letter-spacing: .12em;
    text-transform: uppercase;
    padding: .85rem 2.2rem;
    text-decoration: none;
    border: none;
    cursor: pointer;
    clip-path: polygon(0 0, calc(100% - 12px) 0, 100% 12px, 100% 100%, 12px 100%, 0 calc(100% - 12px));
    transition: box-shadow .2s, transform .15s;
  }
  .btn-primary:hover {
    box-shadow: 0 0 30px rgba(0,255,231,.6);
    transform: translateY(-2px);
  }

  .btn-ghost {
    display: inline-flex; align-items: center; gap: .5rem;
    background: transparent;
    color: var(--cyan);
    font-family: var(--font-mono);
    font-size: .82rem;
    letter-spacing: .12em;
    text-transform: uppercase;
    padding: .83rem 2.2rem;
    border: 1px solid var(--cyan);
    text-decoration: none;
    cursor: pointer;
    clip-path: polygon(0 0, calc(100% - 12px) 0, 100% 12px, 100% 100%, 12px 100%, 0 calc(100% - 12px));
    transition: background .2s, color .2s;
  }
  .btn-ghost:hover { background: rgba(0,255,231,.08); }

  /* Terminal boot animation */
  .terminal-box {
    margin: 3.5rem auto 0;
    max-width: 580px;
    background: rgba(8,15,28,.9);
    border: 1px solid var(--border);
    text-align: left;
    animation: fadeDown .7s ease .5s both;
    position: relative;
    overflow: hidden;
  }
  .terminal-box::before {
    content: '';
    position: absolute; top: 0; left: 0; right: 0;
    height: 2px;
    background: linear-gradient(90deg, transparent, var(--cyan), transparent);
    animation: scanH 2.5s ease-in-out infinite;
  }
  @keyframes scanH {
    0%,100% { opacity: 0; transform: translateX(-100%); }
    50% { opacity: 1; transform: translateX(100%); }
  }
  .term-bar {
    display: flex; align-items: center; gap: .5rem;
    padding: .55rem .9rem;
    background: rgba(0,255,231,.04);
    border-bottom: 1px solid var(--border);
  }
  .term-dot { width: 8px; height: 8px; border-radius: 50%; }
  .term-dot.r { background: var(--red); }
  .term-dot.a { background: var(--amber); }
  .term-dot.g { background: var(--green); }
  .term-title { font-family: var(--font-mono); font-size: .68rem; color: var(--dim); margin-left: .3rem; letter-spacing: .1em; }
  .term-body { padding: 1.1rem 1.3rem; }
  .term-line {
    font-family: var(--font-mono);
    font-size: .75rem;
    color: var(--green);
    display: flex; align-items: flex-start; gap: .4rem;
    margin-bottom: .45rem;
    opacity: 0;
    animation: termLine .15s ease forwards;
  }
  .term-line .p { color: var(--cyan); flex-shrink: 0; }
  .term-line .t { color: var(--text); }
  .term-line .ok { color: var(--green); }
  .term-line .warn { color: var(--amber); }
  .term-cursor {
    display: inline-block; width: 8px; height: .9em;
    background: var(--cyan);
    margin-left: 2px;
    animation: blink .7s step-end infinite;
    vertical-align: middle;
  }
  @keyframes blink { 0%,100% { opacity: 1; } 50% { opacity: 0; } }

  /* staggered delays for terminal lines */
  .term-line:nth-child(1)  { animation-delay: .8s }
  .term-line:nth-child(2)  { animation-delay: 1.1s }
  .term-line:nth-child(3)  { animation-delay: 1.4s }
  .term-line:nth-child(4)  { animation-delay: 1.7s }
  .term-line:nth-child(5)  { animation-delay: 2.0s }
  .term-line:nth-child(6)  { animation-delay: 2.3s }
  .term-line:nth-child(7)  { animation-delay: 2.6s }
  @keyframes termLine { to { opacity: 1; } }

  /* ── SECTIONS COMMON ── */
  section { padding: 6rem 2rem; position: relative; }
  .section-label {
    font-family: var(--font-mono);
    font-size: .68rem;
    letter-spacing: .25em;
    color: var(--cyan);
    text-transform: uppercase;
    margin-bottom: 1rem;
    display: flex; align-items: center; gap: .7rem;
  }
  .section-label::after {
    content: '';
    display: block; height: 1px; flex: 1;
    background: linear-gradient(90deg, var(--border), transparent);
  }
  .section-title {
    font-family: var(--font-ui);
    font-size: clamp(1.8rem, 4vw, 2.8rem);
    font-weight: 700;
    color: #fff;
    margin-bottom: 1rem;
    letter-spacing: -.01em;
  }
  .section-desc {
    color: var(--dim);
    font-size: 1rem;
    max-width: 540px;
    line-height: 1.7;
    font-family: var(--font-mono);
  }
  .container { max-width: 1100px; margin: 0 auto; }

  /* ── FEATURES ── */
  #features { background: var(--bg2); }
  .features-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: 1.2rem;
    margin-top: 3rem;
  }
  .feat-card {
    background: rgba(4,8,16,.7);
    border: 1px solid var(--border);
    padding: 1.8rem;
    position: relative;
    overflow: hidden;
    transition: border-color .25s, transform .25s;
    cursor: default;
  }
  .feat-card::before {
    content: '';
    position: absolute; top: 0; left: 0;
    width: 3px; height: 100%;
    background: var(--cyan);
    opacity: 0;
    transition: opacity .25s;
  }
  .feat-card:hover { border-color: var(--cyan); transform: translateY(-3px); }
  .feat-card:hover::before { opacity: 1; }
  .feat-icon {
    font-size: 1.6rem;
    margin-bottom: 1rem;
    display: block;
  }
  .feat-name {
    font-family: var(--font-ui);
    font-size: 1.1rem;
    font-weight: 700;
    color: #fff;
    margin-bottom: .5rem;
  }
  .feat-desc {
    font-family: var(--font-mono);
    font-size: .75rem;
    color: var(--dim);
    line-height: 1.7;
  }
  .feat-tag {
    display: inline-block;
    margin-top: .8rem;
    font-family: var(--font-mono);
    font-size: .62rem;
    color: var(--cyan2);
    border: 1px solid rgba(0,255,231,.2);
    padding: .18rem .5rem;
    letter-spacing: .1em;
  }

  /* ── HOW TO INSTALL ── */
  #install { background: var(--bg); }
  .install-layout {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 4rem;
    align-items: start;
    margin-top: 3rem;
  }
  .steps { display: flex; flex-direction: column; gap: 1.5rem; }
  .step {
    display: grid;
    grid-template-columns: 48px 1fr;
    gap: 1rem;
    align-items: start;
    opacity: 0;
    transform: translateX(-20px);
    transition: opacity .5s, transform .5s;
  }
  .step.visible { opacity: 1; transform: none; }
  .step-num {
    width: 48px; height: 48px;
    border: 2px solid var(--cyan);
    display: grid; place-items: center;
    font-family: var(--font-mono);
    font-size: 1rem;
    color: var(--cyan);
    flex-shrink: 0;
    clip-path: polygon(0 0, calc(100% - 8px) 0, 100% 8px, 100% 100%, 8px 100%, 0 calc(100% - 8px));
    background: rgba(0,255,231,.05);
  }
  .step-content {}
  .step-title {
    font-family: var(--font-ui);
    font-weight: 700;
    font-size: 1.05rem;
    color: #fff;
    margin-bottom: .3rem;
  }
  .step-text {
    font-family: var(--font-mono);
    font-size: .75rem;
    color: var(--dim);
    line-height: 1.7;
  }
  .step-text code {
    background: rgba(0,255,231,.07);
    color: var(--cyan);
    padding: .1rem .35rem;
    font-family: var(--font-mono);
    font-size: .73rem;
    border: 1px solid rgba(0,255,231,.15);
  }
  .rufus-card {
    background: rgba(8,15,28,.95);
    border: 1px solid var(--border);
    padding: 2rem;
    position: sticky; top: 7rem;
  }
  .rufus-header {
    display: flex; align-items: center; gap: .8rem;
    margin-bottom: 1.5rem;
    padding-bottom: 1rem;
    border-bottom: 1px solid var(--border);
  }
  .rufus-icon { font-size: 2rem; }
  .rufus-name {
    font-family: var(--font-ui);
    font-weight: 700;
    font-size: 1.2rem;
    color: #fff;
  }
  .rufus-ver { font-family: var(--font-mono); font-size: .68rem; color: var(--dim); }
  .rufus-settings { display: flex; flex-direction: column; gap: .9rem; }
  .rufus-field {}
  .rufus-label { font-family: var(--font-mono); font-size: .65rem; color: var(--dim); text-transform: uppercase; letter-spacing: .1em; margin-bottom: .25rem; }
  .rufus-value {
    background: rgba(0,255,231,.04);
    border: 1px solid var(--border);
    padding: .5rem .75rem;
    font-family: var(--font-mono);
    font-size: .78rem;
    color: var(--cyan);
    display: flex; align-items: center; justify-content: space-between;
  }
  .rufus-value .check { color: var(--green); font-size: .8rem; }
  .note-box {
    margin-top: 1.5rem;
    background: rgba(255,210,74,.05);
    border-left: 3px solid var(--amber);
    padding: .8rem 1rem;
    font-family: var(--font-mono);
    font-size: .72rem;
    color: var(--amber);
    line-height: 1.6;
  }

  /* ── SPECS ── */
  #specs { background: var(--bg2); }
  .specs-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
    gap: 1px;
    margin-top: 3rem;
    border: 1px solid var(--border);
    overflow: hidden;
  }
  .spec-item {
    background: rgba(8,15,28,.8);
    padding: 1.5rem;
    border-right: 1px solid var(--border);
    border-bottom: 1px solid var(--border);
    transition: background .2s;
  }
  .spec-item:hover { background: rgba(0,255,231,.04); }
  .spec-key { font-family: var(--font-mono); font-size: .65rem; color: var(--dim); text-transform: uppercase; letter-spacing: .12em; margin-bottom: .5rem; }
  .spec-val { font-family: var(--font-mono); font-size: 1.05rem; color: var(--cyan); font-weight: 700; }
  .spec-val.green { color: var(--green); }

  /* ── DOWNLOAD CTA ── */
  #download {
    background: var(--bg);
    padding: 7rem 2rem;
    text-align: center;
    position: relative;
    overflow: hidden;
  }
  #download::before {
    content: '';
    position: absolute; bottom: -200px; left: 50%; transform: translateX(-50%);
    width: 800px; height: 400px;
    background: radial-gradient(ellipse, rgba(0,255,231,.1) 0%, transparent 65%);
    pointer-events: none;
  }
  .dl-version {
    font-family: var(--font-mono);
    font-size: .75rem;
    color: var(--dim);
    margin-top: 1.5rem;
    letter-spacing: .1em;
  }
  .dl-size {
    display: inline-block;
    font-family: var(--font-mono);
    font-size: .7rem;
    color: var(--green);
    border: 1px solid rgba(57,255,106,.25);
    padding: .3rem .8rem;
    margin-top: .8rem;
  }

  /* ── FOOTER ── */
  footer {
    border-top: 1px solid var(--border);
    padding: 2.5rem 2rem;
    text-align: center;
    font-family: var(--font-mono);
    font-size: .7rem;
    color: var(--dim);
    background: var(--bg2);
  }
  footer span { color: var(--cyan); }

  /* ── ANIMATIONS ── */
  @keyframes fadeDown {
    from { opacity: 0; transform: translateY(-14px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  /* ── FAQ ── */
  .faq-list { margin-top: 3rem; display: flex; flex-direction: column; gap: .6rem; }
  .faq-item {
    border: 1px solid var(--border);
    background: rgba(4,8,16,.7);
    overflow: hidden;
  }
  .faq-q {
    width: 100%; display: flex; justify-content: space-between; align-items: center;
    padding: 1.1rem 1.5rem;
    background: none; border: none; cursor: pointer;
    font-family: var(--font-ui); font-size: 1rem; font-weight: 600;
    color: #fff; text-align: left; gap: 1rem;
    transition: background .2s;
  }
  .faq-q:hover { background: rgba(0,255,231,.04); }
  .faq-q.open { color: var(--cyan); }
  .faq-arrow { color: var(--dim); font-size: .7rem; flex-shrink: 0; transition: transform .25s; }
  .faq-q.open .faq-arrow { transform: rotate(180deg); color: var(--cyan); }
  .faq-a {
    font-family: var(--font-mono); font-size: .78rem; color: var(--dim);
    line-height: 1.8; padding: 0 1.5rem;
    max-height: 0; overflow: hidden;
    transition: max-height .35s ease, padding .25s ease;
  }
  .faq-a code {
    background: rgba(0,255,231,.07); color: var(--cyan);
    padding: .1rem .35rem; border: 1px solid rgba(0,255,231,.15);
    font-family: var(--font-mono); font-size: .73rem;
  }
  .faq-a.open { max-height: 300px; padding: .2rem 1.5rem 1.2rem; }

  /* ── SUPPORT ── */
  .support-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1.5rem;
    margin-top: 3rem;
  }
  .support-card {
    border: 1px solid var(--border);
    background: rgba(8,15,28,.9);
    padding: 2rem;
    display: flex; flex-direction: column; gap: 1.2rem;
    position: relative; overflow: hidden;
    transition: border-color .25s, transform .2s;
  }
  .support-card::after {
    content: '';
    position: absolute; top: 0; left: 0; right: 0; height: 2px;
    opacity: 0; transition: opacity .25s;
  }
  .discord-card::after { background: linear-gradient(90deg, #5865F2, #7289DA); }
  .gmail-card::after   { background: linear-gradient(90deg, #EA4335, #FBBC05); }
  .support-card:hover { transform: translateY(-4px); }
  .discord-card:hover { border-color: rgba(88,101,242,.6); }
  .gmail-card:hover   { border-color: rgba(234,67,53,.5); }
  .support-card:hover::after { opacity: 1; }

  .support-card-top { display: flex; align-items: center; gap: 1rem; }
  .support-icon {
    width: 56px; height: 56px;
    display: grid; place-items: center;
    border: 1px solid var(--border);
    flex-shrink: 0;
    clip-path: polygon(0 0, calc(100% - 8px) 0, 100% 8px, 100% 100%, 8px 100%, 0 calc(100% - 8px));
  }
  .discord-icon { background: rgba(88,101,242,.12); color: #7289DA; }
  .gmail-icon   { background: rgba(234,67,53,.1);  color: #EA4335; }
  .support-platform {
    font-family: var(--font-ui); font-weight: 700; font-size: 1.2rem; color: #fff;
  }
  .support-handle { font-family: var(--font-mono); font-size: .7rem; color: var(--dim); margin-top: .15rem; }

  .support-desc {
    font-family: var(--font-mono); font-size: .76rem; color: var(--dim); line-height: 1.75;
  }
  .support-desc strong { color: var(--text); }

  .support-perks { display: flex; flex-wrap: wrap; gap: .5rem; }
  .perk {
    font-family: var(--font-mono); font-size: .65rem;
    padding: .25rem .65rem;
    border: 1px solid var(--border);
    color: var(--text);
  }

  .btn-support {
    display: inline-flex; align-items: center;
    font-family: var(--font-mono); font-size: .78rem; font-weight: 700;
    letter-spacing: .1em; text-transform: uppercase;
    padding: .75rem 1.5rem; text-decoration: none; border: none; cursor: pointer;
    clip-path: polygon(0 0, calc(100% - 10px) 0, 100% 10px, 100% 100%, 10px 100%, 0 calc(100% - 10px));
    transition: box-shadow .2s, transform .15s; margin-top: auto;
  }
